---
import '../styles/global.css';
const BASE = import.meta.env.BASE_URL;
const { title = "Mo Services Erbach – Professionelle Reinigung mit Herz" } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Mo Services Erbach – professionelle Reinigung für Privat und Gewerbe. Sauberkeit ist unsere Mission, Ihre Zufriedenheit unser Versprechen." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
</head>
<body class="antialiased">

  <div id="cursor-halo" class="hidden md:block"></div>

  <!-- HEADER -->
  <header class="fixed top-0 left-0 right-0 z-50">
    <div class="bg-[#0E1015]/88 backdrop-blur-xl border-b border-white/5">
      <div class="max-w-7xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between gap-4">

        <!-- Logo -->
        <a href={`${BASE}`} class="flex items-center gap-3 flex-shrink-0">
          <!-- Wing icon referencing the logo -->
          <div class="flex items-center gap-2">
            <svg width="36" height="20" viewBox="0 0 80 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M40 18 C30 8, 10 4, 0 10 C8 12, 16 14, 20 18 C16 14, 8 16, 2 24 C12 20, 28 20, 40 18Z" fill="#6B82B0" opacity="0.9"/>
              <path d="M40 18 C50 8, 70 4, 80 10 C72 12, 64 14, 60 18 C64 14, 72 16, 78 24 C68 20, 52 20, 40 18Z" fill="#6B82B0" opacity="0.9"/>
            </svg>
            <div class="leading-tight">
              <span class="font-display font-bold text-white text-sm tracking-widest uppercase">Mo Services</span>
              <p class="text-[10px] text-[#6B82B0]/80 font-medium tracking-widest uppercase">Erbach</p>
            </div>
          </div>
        </a>

        <!-- Nav -->
        <nav class="hidden lg:flex items-center gap-6">
          {["Leistungen", "Galerie", "Bewertungen", "Über uns", "Kontakt"].map(item => (
            <a href={`#${item.toLowerCase().replace('ü','ue').replace(' ','-')}`}
               class="text-white/60 hover:text-white text-sm font-medium transition-colors duration-200 tracking-wide">
              {item}
            </a>
          ))}
        </nav>

        <!-- Phone + CTA -->
        <div class="flex items-center gap-3 flex-shrink-0">
          <a href="tel:+4915141331121" class="hidden md:flex items-center gap-2 text-white/70 hover:text-white text-sm font-medium transition-colors duration-200">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.92 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            01514 133 1121
          </a>
          <div class="hidden md:block w-px h-5 bg-white/15"></div>
          <a href="#kontakt" class="bg-[#6B82B0] hover:bg-[#8FA3C8] text-white text-sm font-semibold px-4 py-2 rounded-lg transition-all duration-200 hover:scale-105 hover:shadow-[0_0_20px_rgba(107,130,176,0.4)] active:scale-100 tracking-wide">
            Angebot anfragen
          </a>
          <a href="tel:+4915141331121" class="md:hidden text-white/70 p-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.92 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="h-px bg-gradient-to-r from-transparent via-[#6B82B0]/25 to-transparent"></div>
  </header>

  <main><slot /></main>

  <!-- FOOTER -->
  <footer class="bg-[#080A0D] text-white/50 py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <!-- Wing divider top -->
      <div class="flex justify-center mb-12 opacity-15">
        <svg width="200" height="40" viewBox="0 0 200 40" fill="none">
          <path d="M100 20 C75 5, 30 2, 0 12 C20 15, 45 17, 55 20 C45 17, 22 20, 5 30 C30 24, 72 22, 100 20Z" fill="#6B82B0"/>
          <path d="M100 20 C125 5, 170 2, 200 12 C180 15, 155 17, 145 20 C155 17, 178 20, 195 30 C170 24, 128 22, 100 20Z" fill="#6B82B0"/>
        </svg>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
        <div>
          <p class="font-display font-bold text-white tracking-widest uppercase mb-2">Mo Services</p>
          <p class="text-[10px] text-[#6B82B0]/70 tracking-widest uppercase mb-4">Erbach</p>
          <p class="text-sm leading-relaxed">Professionelle Reinigung für Privat und Gewerbe im Odenwald. Sauberkeit ist unsere Mission, Ihre Zufriedenheit unser Versprechen.</p>
        </div>
        <div>
          <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-4">Navigation</h4>
          <ul class="space-y-2 text-sm">
            {["Leistungen", "Galerie", "Bewertungen", "Über uns", "Kontakt"].map(item => (
              <li><a href={`#${item.toLowerCase().replace('ü','ue')}`} class="hover:text-white transition-colors">{item}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-4">Kontakt</h4>
          <ul class="space-y-3 text-sm">
            <li class="flex items-center gap-2">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.92 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:+4915141331121" class="hover:text-white transition-colors">01514 133 1121</a>
            </li>
            <li class="flex items-start gap-2">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Am Krebsbach 3, 64711 Erbach</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/8 pt-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs">
        <p>© 2024 Mo Services · Alle Rechte vorbehalten</p>
        <div class="flex gap-4">
          <a href="#" class="hover:text-white transition-colors">Impressum</a>
          <a href="#" class="hover:text-white transition-colors">Datenschutz</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- WHATSAPP -->
  <a href="https://wa.me/4915141331121" target="_blank" rel="noopener"
     class="fixed bottom-24 right-4 md:bottom-8 md:right-6 z-50 bg-[#25D366] hover:bg-[#20BA5A] text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-all duration-200 hover:scale-110 hover:shadow-[0_0_24px_rgba(37,211,102,0.5)] active:scale-100">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
  </a>

  <!-- MOBILE STICKY BAR -->
  <div class="fixed bottom-0 left-0 right-0 z-50 md:hidden flex">
    <a href="tel:+4915141331121" class="flex-1 bg-[#0E1015] text-white flex items-center justify-center gap-2 py-4 text-sm font-semibold border-r border-white/10">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.92 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Jetzt anrufen
    </a>
    <a href="#kontakt" class="flex-1 bg-[#6B82B0] text-white flex items-center justify-center gap-2 py-4 text-sm font-semibold">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      Termin buchen
    </a>
  </div>

  <!-- INACTIVITY POPUP -->
  <div id="inactivity-popup" class="fixed inset-0 z-[100] flex items-center justify-center p-4 hidden">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="popup-overlay"></div>
    <div class="relative bg-[#0E1015] border border-[#6B82B0]/20 rounded-2xl p-8 max-w-md w-full shadow-2xl">
      <button id="popup-close" class="absolute top-4 right-4 text-white/30 hover:text-white/70 transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
      <div class="text-center">
        <div class="flex justify-center mb-5 opacity-60">
          <svg width="60" height="28" viewBox="0 0 120 40" fill="none">
            <path d="M60 20 C45 5, 18 2, 0 12 C12 15, 27 17, 33 20 C27 17, 13 20, 3 30 C18 24, 43 22, 60 20Z" fill="#6B82B0"/>
            <path d="M60 20 C75 5, 102 2, 120 12 C108 15, 93 17, 87 20 C93 17, 107 20, 117 30 C102 24, 77 22, 60 20Z" fill="#6B82B0"/>
          </svg>
        </div>
        <h3 class="font-display font-bold text-white text-xl mb-2 tracking-wide">Haben Sie Fragen?</h3>
        <p class="text-white/40 text-sm mb-6">Wir rufen Sie kostenlos und unverbindlich zurück.</p>
        <form id="popup-form" class="space-y-3">
          <input type="text" placeholder="Ihr Name *" required class="w-full bg-white/5 border border-white/10 focus:border-[#6B82B0]/50 text-white rounded-lg px-4 py-3 text-sm outline-none transition-colors placeholder:text-white/30" />
          <input type="tel" placeholder="Ihre Telefonnummer *" required class="w-full bg-white/5 border border-white/10 focus:border-[#6B82B0]/50 text-white rounded-lg px-4 py-3 text-sm outline-none transition-colors placeholder:text-white/30" />
          <button type="submit" class="w-full bg-[#6B82B0] hover:bg-[#8FA3C8] text-white font-semibold py-3 rounded-lg transition-all duration-200 hover:scale-[1.02] active:scale-100 tracking-wide">
            Jetzt zurückrufen lassen
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    const halo = document.getElementById('cursor-halo');
    if (halo && window.innerWidth >= 768) {
      document.addEventListener('mousemove', (e) => { halo.style.left = e.clientX+'px'; halo.style.top = e.clientY+'px'; });
    }
    let timer: ReturnType<typeof setTimeout>;
    const popup = document.getElementById('inactivity-popup');
    function showPopup() { if (!sessionStorage.getItem('popupShown') && popup) { popup.classList.remove('hidden'); sessionStorage.setItem('popupShown','1'); } }
    function reset() { clearTimeout(timer); timer = setTimeout(showPopup, 30000); }
    ['mousemove','scroll','click','keypress','touchstart'].forEach(e => document.addEventListener(e, reset, { passive: true }));
    reset();
    document.getElementById('popup-overlay')?.addEventListener('click', () => popup?.classList.add('hidden'));
    document.getElementById('popup-close')?.addEventListener('click', () => popup?.classList.add('hidden'));
    document.getElementById('popup-form')?.addEventListener('submit', e => { e.preventDefault(); popup?.classList.add('hidden'); });

    const obs = new IntersectionObserver(entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }), { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));

    function animateCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.target || '0');
      const start = performance.now();
      function upd(now: number) {
        const p = Math.min((now-start)/1800,1), ease = 1-Math.pow(1-p,3);
        el.textContent = Math.floor(ease*target).toLocaleString('de-DE');
        if (p < 1) requestAnimationFrame(upd);
      }
      requestAnimationFrame(upd);
    }
    const cObs = new IntersectionObserver(entries => entries.forEach(e => {
      const el = e.target as HTMLElement;
      if (e.isIntersecting && !el.dataset.animated) { el.dataset.animated='1'; animateCounter(el); }
    }), { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => cObs.observe(el as HTMLElement));
  </script>
</body>
</html>
